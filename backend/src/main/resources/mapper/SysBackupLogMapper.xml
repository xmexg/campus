<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.legal.mapper.SysBackupLogMapper">

    <resultMap id="BaseMap" type="com.campus.legal.entity.SysBackupLog">
        <id column="id" property="id"/>
        <result column="operator_id" property="operatorId"/>
        <result column="backup_type" property="backupType"/>
        <result column="file_path" property="filePath"/>
        <result column="remark" property="remark"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_backup_log (operator_id, backup_type, file_path, remark)
        VALUES (#{operatorId}, #{backupType}, #{filePath}, #{remark})
    </insert>

    <select id="listRecent" resultMap="BaseMap">
        SELECT * FROM sys_backup_log ORDER BY id DESC LIMIT #{limit}
    </select>
</mapper>
