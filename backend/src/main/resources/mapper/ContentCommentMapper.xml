<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.legal.mapper.ContentCommentMapper">

    <resultMap id="BaseMap" type="com.campus.legal.entity.ContentComment">
        <id column="id" property="id"/>
        <result column="content_id" property="contentId"/>
        <result column="user_id" property="userId"/>
        <result column="body" property="body"/>
        <result column="hidden" property="hidden"/>
        <result column="created_at" property="createdAt"/>
        <result column="nickname" property="nickname"/>
        <result column="username" property="username"/>
    </resultMap>

<!--    旧的查评论-->
<!--    <select id="listByContent" resultMap="BaseMap">-->
<!--        SELECT * FROM content_comment WHERE content_id = #{contentId} AND hidden = 0 ORDER BY id ASC-->
<!--    </select>-->
<!--    新的查评论-->
    <select id="listByContent" resultMap="BaseMap">
        SELECT cc.*, su.nickname, su.username
        FROM content_comment cc
                 LEFT JOIN sys_user su ON cc.user_id = su.id
        WHERE cc.content_id = #{contentId} AND cc.hidden = 0
        ORDER BY cc.id ASC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO content_comment (content_id, user_id, body, hidden) VALUES (#{contentId}, #{userId}, #{body}, #{hidden})
    </insert>

    <update id="setHidden">
        UPDATE content_comment SET hidden = #{hidden} WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM content_comment WHERE id = #{id}
    </delete>
</mapper>
